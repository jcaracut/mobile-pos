{
  "expo": {
    "name": "Tugkaran POS",
    "slug": "tugkaran",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "tugkaran",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#402010",
      "imageWidth": 578
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#402010"
      },
      "package": "com.tugkaran.pos"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    }, 
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tugkaran.pos"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a69eff1f-4cdd-44cf-a673-39bee3a20857"
      }
    },
    "owner": "jecson-caracuts-organization"
  }
}
